# Supabase Configuration
# Create a Supabase project at https://supabase.com
# Copy these values from Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for admin operations (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional E2E smoke credentials (Playwright)
# E2E_USER_EMAIL=test-user@example.com
# E2E_USER_PASSWORD=your-password
# E2E_OBRA_ID=uuid-of-an-existing-obra-in-user-scope
